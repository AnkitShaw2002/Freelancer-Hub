<%- include('layout/header') %>
    <%- include('layout/flash') %>

        <body>
    <%- include('layout/navbar') %>

            <section class="hero-section py-5">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-lg-6 mb-5 mb-lg-0">
                            <span class="badge bg-primary-soft text-primary px-3 py-2 rounded-pill mb-3">#1 AI-Powered
                                Marketplace</span>
                            <h1 class="display-3 fw-bold mb-4">Connect. Collaborate. <br><span
                                    class="text-primary">Create Success.</span></h1>
                            <p class="lead text-muted mb-5 pe-lg-5">Find top talent, manage projects, and get work done
                                with our secure platform powered by AI.</p>

                            <div class="d-flex gap-3 mb-5">
                                <a href="/projects/create" class="btn btn-primary btn-lg px-4 py-3 rounded-3 shadow">Post a Project <i
                                        class="bi bi-arrow-right ms-2"></i></a>
                                <a href="/projects" class="btn btn-outline-secondary btn-lg px-4 py-3 rounded-3 custom-btn-outline">Find
                                    Work <i class="bi bi-briefcase ms-2"></i></a>
                            </div>

                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar-group d-flex">
                                    <img src="/images/review3-landingPage.jpg"
                                        class="rounded-circle border border-white" alt="User 1">
                                    <img src="/images/review2-landingPage.jpg"
                                        class="rounded-circle border border-white ms-n2" alt="User 2">
                                    <img src="/images/review1-landingPage.jpg"
                                        class="rounded-circle border border-white ms-n2" alt="User 3">
                                </div>
                                <span class="small text-muted fw-bold">Join 10,000+ users growing their business</span>
                            </div>
                        </div>

                        <div class="col-lg-6 position-relative text-center">
                            <img src="/images/hero-man.png" class="img-fluid rounded-4 main-hero-img" alt="Freelancer">

                            <div class="floating-card ai-card p-3 shadow-lg animate-up-down">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="icon-box-sm bg-primary-soft text-primary me-2"><i
                                            class="bi bi-stars"></i></div>
                                    <span class="fw-bold small text-label-emphasis">AI Project Analysis</span>
                                </div>
                                <div class="small text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i>
                                    Skills Matched</div>
                                <div class="small text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i>
                                    Budget Estimation</div>
                            </div>

                            <div class="floating-card freelancer-card shadow-sm p-3 animate-up-down-delayed">
                                <div class="small fw-bold mb-1 text-label-emphasis">Top Freelancer</div>
                                <div class="d-flex align-items-center">
                                    <img src="https://i.pravatar.cc/30?img=4" class="rounded-circle me-1"
                                        alt="Freelancer">
                                    <span class="small text-warning"><i class="bi bi-star-fill"></i> 4.9 <span
                                            class="text-muted">(128)</span></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="stats-section pb-5">
                <div class="container">
                    <div class="stats-box shadow-sm rounded-5 py-4 px-5">
                        <div class="row text-center gy-4">
                            <div class="col-6 col-md-3 border-end">
                                <h2 class="fw-bold mb-0">10K+</h2>
                                <p class="text-muted small mb-0">Active Users</p>
                            </div>
                            <div class="col-6 col-md-3 border-end">
                                <h2 class="fw-bold mb-0">5K+</h2>
                                <p class="text-muted small mb-0">Projects Completed</p>
                            </div>
                            <div class="col-6 col-md-3 border-end">
                                <h2 class="fw-bold mb-0">98%</h2>
                                <p class="text-muted small mb-0">Success Rate</p>
                            </div>
                            <div class="col-6 col-md-3">
                                <h2 class="fw-bold mb-0">$2M+</h2>
                                <p class="text-muted small mb-0">Total Earned</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="features-section py-5">
                <div class="container text-center mb-5">
                    <span class="text-primary fw-bold small text-uppercase tracking-wider">Why Choose Us</span>
                    <h2 class="fw-bold display-6 mt-2">Everything You Need to Succeed</h2>
                    <p class="text-muted mx-auto" style="max-width: 600px;">Powerful features designed to help you find
                        work, hire talent, and manage projects efficiently.</p>

                    <div class="row mt-5 g-4">
                        <div class="col-md-3">
                            <div class="feature-card h-100 p-4 rounded-4 shadow-sm text-start">
                                <div class="icon-box mb-3 rounded-3 d-flex align-items-center justify-content-center bg-primary text-white"
                                    style="width: 45px; height: 45px;">
                                    <i class="bi bi-stars"></i>
                                </div>
                                <h6 class="fw-bold">AI-Powered Matching</h6>
                                <p class="text-muted small mb-0">Our AI analyzes your project requirements to match you
                                    with the perfect talent.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="feature-card h-100 p-4 rounded-4 shadow-sm text-start">
                                <div class="icon-box mb-3 rounded-3 d-flex align-items-center justify-content-center bg-success text-white"
                                    style="width: 45px; height: 45px;">
                                    <i class="bi bi-shield-check"></i>
                                </div>
                                <h6 class="fw-bold">Secure Payments</h6>
                                <p class="text-muted small mb-0">Escrow protection ensures safe transactions for both
                                    parties.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="feature-card h-100 p-4 rounded-4 shadow-sm text-start">
                                <div class="icon-box mb-3 rounded-3 d-flex align-items-center justify-content-center bg-info text-white"
                                    style="width: 45px; height: 45px;">
                                    <i class="bi bi-chat-dots"></i>
                                </div>
                                <h6 class="fw-bold">Real-time Chat</h6>
                                <p class="text-muted small mb-0">Built-in tools keep your projects moving forward
                                    seamlessly.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="feature-card h-100 p-4 rounded-4 shadow-sm text-start">
                                <div class="icon-box mb-3 rounded-3 d-flex align-items-center justify-content-center bg-warning text-white"
                                    style="width: 45px; height: 45px;">
                                    <i class="bi bi-bar-chart-steps"></i>
                                </div>
                                <h6 class="fw-bold">Management</h6>
                                <p class="text-muted small mb-0">Track progress and manage deadlines all in one place.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

    <%- include('layout/footer') %>
        </body>
</html>