<div id="toast-container"></div>
<script>
  // Initialize socket and expose globally
  if (typeof io !== 'undefined') {
    const socket = io();
    window._socket = socket;
    const meta = document.querySelector('meta[name="user-id"]');
    if (meta && meta.content) {
      socket.emit('join', meta.content);
    }
    socket.on('notification', function(data) {
      showToast(data.message || data);
      // Update notification badge if exists
      const badge = document.getElementById('notif-badge'); // Assuming there's one, or use a generic selector
    });

    socket.on('message', function(data) {
      // data: { senderName, content, conversationId }
      showToast(`New message from ${data.senderName}: ${data.content.substring(0, 30)}...`);
      
      // Update message badge
      let badge = document.getElementById('message-badge');
      if (badge) {
        let count = parseInt(badge.textContent) || 0;
        badge.textContent = count + 1 > 9 ? '9+' : count + 1;
      } else {
        const link = document.getElementById('message-nav-link');
        if (link) {
          const newBadge = document.createElement('span');
          newBadge.id = 'message-badge';
          newBadge.className = 'position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary';
          newBadge.style.fontSize = '0.6rem';
          newBadge.textContent = '1';
          link.appendChild(newBadge);
        }
      }
    });

    function showToast(msg) {
      const container = document.getElementById('toast-container');
      if (!container) return;
      const toast = document.createElement('div');
      toast.className = 'toast show border-0 shadow-sm rounded-3 p-3 mb-2 bg-white';
      toast.style.minWidth = '250px';
      toast.innerHTML = `<div class="d-flex align-items-center gap-2"><i class="bi bi-info-circle text-primary"></i> <div>${msg}</div></div>`;
      container.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.5s ease';
        setTimeout(() => toast.remove(), 500);
      }, 4000);
    }
  }
</script>
