<nav class="navbar navbar-expand-lg sticky-top bg-white border-bottom">
    <div class="container">
        <a class="navbar-brand fw-bold text-primary fs-4" href="/">
            <i class="bi bi-hexagon-fill me-2"></i>FreelancerHub
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4 gap-2">
                <li class="nav-item">
                    <a class="nav-link custom-nav-link" href="/projects">Browse Projects</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link custom-nav-link" href="/freelancers">Find Freelancers</a>
                </li>

                <% if (currentUser) { %>
                    <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
                    
                    <% if (currentUser.role === 'client') { %>
                        <li class="nav-item"><a class="nav-link text-primary fw-semibold" href="/client/projects/create">Post a Job</a></li>
                    <% } %>

                    <% if (currentUser.role === 'admin') { %>
                        <li class="nav-item"><a class="nav-link" href="/admin">Admin</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/disputes">Disputes</a></li>
                    <% } %>
                <% } %>
            </ul>

            <div class="d-flex align-items-center gap-3">
                
                <button class="btn btn-link text-muted p-0 me-1" id="themeToggle" title="Toggle Dark Mode">
                    <i class="bi bi-moon-stars fs-5"></i>
                </button>

                <% if (currentUser) { %>
                    <a href="/messages" class="text-muted position-relative" title="Messages" id="message-nav-link">
                        <i class="bi bi-envelope fs-5"></i>
                        <% if (typeof unreadMessagesCount !== 'undefined' && unreadMessagesCount > 0) { %>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" style="font-size: 0.6rem;" id="message-badge">
                                <%= unreadMessagesCount > 9 ? '9+' : unreadMessagesCount %>
                            </span>
                        <% } %>
                    </a>

                    <a href="/notifications" class="text-muted position-relative me-2" title="Notifications">
                        <i class="bi bi-bell fs-5"></i>
                        <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                                <%= unreadCount > 9 ? '9+' : unreadCount %>
                            </span>
                        <% } %>
                    </a>

                    <div class="dropdown">
                        <div class="d-flex align-items-center gap-2 cursor-pointer" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                            <div class="text-end d-none d-sm-block">
                                <p class="mb-0 fw-bold small" style="line-height: 1;">
                                    <%= currentUser.name.split(' ')[0] %>
                                </p>
                                <small class="text-muted" style="font-size: 0.7rem; text-transform: capitalize;">
                                    <%= currentUser.role %>
                                </small>
                            </div>
                            <% if (currentUser.avatar || currentUser.profileImage) { %>
                                <img src="<%= currentUser.avatar || currentUser.profileImage %>" alt="Profile"
                                    class="rounded-circle border" style="width: 38px; height: 38px; object-fit: cover;">
                            <% } else { %>
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold border" 
                                     style="width: 38px; height: 38px; font-size: 0.9rem;">
                                    <%= currentUser.name.charAt(0).toUpperCase() %>
                                </div>
                            <% } %>
                        </div>
                        
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 animate slideIn">
                            <li><a class="dropdown-item py-2" href="/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                            <li><a class="dropdown-item py-2" href="/profile"><i class="bi bi-person me-2"></i> My Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                        </ul>
                    </div>

                <% } else { %>
                    <a href="/login" class="btn btn-link text-decoration-none nav-link-custom fw-semibold px-3">Log In</a>
                    <a href="/register" class="btn btn-primary px-4 rounded-pill shadow-sm fw-bold">Get Started</a>
                <% } %>
            </div>
        </div>
    </div>
</nav>