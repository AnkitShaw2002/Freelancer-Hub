<%- include('../layout/header') %>
<%- include('../layout/navbar') %>
<div class="page">
  <div class="page-header">
    <h1>⚖️ Manage Disputes</h1>
    <p class="page-subtitle">Review and resolve open disputes between clients and freelancers.</p>
  </div>
  <%- include('../layout/flash') %>

  <!-- Filter tabs -->
  <div style="display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap;">
    <% ['','open','under-review','resolved'].forEach(function(s){ %>
      <a href="/admin/disputes<%= s ? '?status='+s : '' %>"
         class="btn btn-sm <%= (!query.status && !s) || query.status===s ? 'btn-primary' : 'btn-ghost' %>">
        <%= s ? s.charAt(0).toUpperCase()+s.slice(1).replace('-',' ') : 'All' %>
        <% if (counts[s||'all']) { %><span style="margin-left:.3rem;opacity:.7;">(<%= counts[s||'all'] %>)</span><% } %>
      </a>
    <% }) %>
  </div>

  <% if (disputes.length === 0) { %>
    <div class="card" style="text-align:center;padding:3rem;">
      <div style="font-size:2.5rem;margin-bottom:.75rem;">⚖️</div>
      <h3>No disputes found</h3>
      <p style="color:var(--dark4);">All clear!</p>
    </div>
  <% } else { %>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      <% disputes.forEach(function(d){ %>
        <div class="card" style="padding:1.25rem;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:.75rem;">
            <div style="flex:1;min-width:220px;">
              <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.4rem;">
                <span class="badge badge-<%= d.status==='open'?'warning':d.status==='under-review'?'info':'success' %>">
                  <%= d.status %>
                </span>
                <span style="font-size:.78rem;color:var(--dark4);">
                  <%= new Date(d.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
                </span>
              </div>
              <div style="font-weight:700;font-size:1rem;margin-bottom:.25rem;">
                <a href="/projects/<%= d.projectId %>" style="color:var(--dark1);">📁 <%= d.projectTitle %></a>
              </div>
              <div style="font-size:.85rem;color:var(--dark3);margin-bottom:.3rem;">
                <strong>Raised by:</strong> <%= d.initiatorName %> &nbsp;→&nbsp; <strong>Against:</strong> <%= d.respondentName %>
              </div>
              <div style="font-size:.85rem;color:var(--dark3);">
                <strong>Reason:</strong> <%= d.reason.replace(/-/g,' ') %>
              </div>
              <p style="font-size:.85rem;color:var(--dark4);margin:.5rem 0 0;line-height:1.5;">
                <%= d.description.length > 180 ? d.description.substring(0,180)+'…' : d.description %>
              </p>
              <% if (d.evidence && d.evidence.length) { %>
                <div style="margin-top:.4rem;font-size:.8rem;color:var(--primary);">
                  📎 <%= d.evidence.length %> evidence item(s)
                </div>
              <% } %>
              <% if (d.resolution) { %>
                <div style="margin-top:.5rem;padding:.5rem .75rem;background:#f0fdf4;border-radius:7px;font-size:.83rem;color:#166534;">
                  ✅ <strong>Resolution:</strong> <%= d.resolution %>
                </div>
              <% } %>
            </div>

            <% if (d.status !== 'resolved') { %>
              <div style="display:flex;flex-direction:column;gap:.5rem;min-width:200px;">
                <form method="POST" action="/admin/disputes/<%= d._id %>/resolve">
                  <textarea name="resolution" class="form-control" rows="2" placeholder="Enter resolution decision..." required
                    style="font-size:.82rem;margin-bottom:.5rem;"></textarea>
                  <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                    <button name="action" value="resolve-client" class="btn btn-sm btn-ghost" style="flex:1;">Favor Client</button>
                    <button name="action" value="resolve-freelancer" class="btn btn-sm btn-primary" style="flex:1;">Favor Freelancer</button>
                  </div>
                  <% if (d.status === 'open') { %>
                    <button name="action" value="review" class="btn btn-sm btn-ghost" style="width:100%;margin-top:.3rem;font-size:.78rem;">Mark Under Review</button>
                  <% } %>
                </form>
              </div>
            <% } else { %>
              <div style="text-align:right;font-size:.8rem;color:var(--dark4);">
                Resolved by <%= d.resolvedBy %><br>
                <%= new Date(d.resolvedAt).toLocaleDateString('en-IN') %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div style="display:flex;justify-content:center;gap:.5rem;margin-top:1.5rem;">
      <% for(let i=1;i<=totalPages;i++){ %>
        <a href="?status=<%= query.status||'' %>&page=<%= i %>"
           class="btn btn-sm <%= currentPage===i?'btn-primary':'btn-ghost' %>"><%= i %></a>
      <% } %>
    </div>
  <% } %>
</div>
<%- include('../layout/footer') %>
