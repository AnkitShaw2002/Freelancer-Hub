<%- include('layout/header') %>

<main class="d-flex align-items-center justify-content-center" style="min-height: 100vh; background: radial-gradient(circle at top right, var(--border-color), transparent), var(--bg-main);">
    
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-6 col-lg-4">
                
                <div class="text-center mb-4">
                    <a href="/" class="text-decoration-none fw-bold text-primary fs-3">
                        <i class="bi bi-hexagon-fill me-2"></i>FreelancerHub
                    </a>
                </div>

                <div class="card border-0 shadow-sm p-4 p-md-5 rounded-4">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold h4">Welcome back</h2>
                        <p class="text-muted small">Enter your details to access your account</p>
                    </div>

                    <% if (typeof messages !== 'undefined') { %>
                        <% if (messages.error && messages.error.length > 0) { %>
                            <div class="alert alert-danger border-0 small rounded-3 py-2" role="alert">
                                <i class="bi bi-exclamation-circle me-2"></i><%= messages.error %>
                            </div>
                        <% } %>
                        <% if (messages.success && messages.success.length > 0) { %>
                            <div class="alert alert-success border-0 small rounded-3 py-2" role="alert">
                                <i class="bi bi-check-circle me-2"></i><%= messages.success %>
                            </div>
                        <% } %>
                    <% } %>

                    <form action="/auth/login-create" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-envelope text-muted"></i></span>
                                <input type="email" name="email" class="form-control bg-light border-0" placeholder="name@example.com" required autofocus>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between">
                                <label class="form-label small fw-bold">Password</label>
                                <a href="/forgot-password" class="text-primary text-decoration-none small">Forgot?</a>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-key text-muted"></i></span>
                                <input type="password" name="password" class="form-control bg-light border-0" placeholder="••••••••" required>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold shadow-sm rounded-3">
                            Sign In
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0">Don't have an account?</p>
                        <a href="/register" class="text-primary fw-bold text-decoration-none">Create an account</a>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <a href="/" class="text-muted small text-decoration-none hover-primary">
                        <i class="bi bi-arrow-left me-1"></i> Back to Homepage
                    </a>
                </div>

                <div class="mt-4 p-3 bg-white border border-dashed rounded-4 opacity-75">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-info-circle text-primary me-2"></i>
                        <span class="small fw-bold text-muted">Testing Credentials</span>
                    </div>
                    <div class="d-grid gap-1">
                        <code class="x-small text-muted bg-light p-1 rounded">Admin: Arnab Singh /arnab@yopmail.com / Admin123</code>
                        <code class="x-small text-muted bg-light p-1 rounded">Client: Vikram Mehra/vikram@yopmail.com / Client123</code>
                        <code class="x-small text-muted bg-light p-1 rounded">Freelancer: Arjun Verma/ arjun@yopmail.com / Freelancer123</code>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>

<%- include('layout/footer') %>