<%- include('../layout/header') %>
<%- include('../layout/navbar') %>
<div class="page" style="max-width:700px;">
  <div class="page-header">
    <h1>📄 AI-Generated Contract</h1>
    <p class="page-subtitle">Review this auto-generated agreement between you and your freelancer.</p>
  </div>
  <%- include('../layout/flash') %>
  <div class="card" style="margin-bottom:1rem;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;flex-wrap:wrap;gap:.5rem;">
      <div>
        <div style="font-weight:700;font-size:1.05rem;"><%= project.title %></div>
        <div style="font-size:.85rem;color:var(--dark4);">
          Client: <strong><%= project.clientName %></strong> ·
          Freelancer: <strong><%= project.freelancerName %></strong>
        </div>
      </div>
      <div style="display:flex;gap:.5rem;">
        <button onclick="window.print()" class="btn btn-ghost btn-sm">🖨️ Print</button>
        <a href="/projects/<%= project._id %>" class="btn btn-ghost btn-sm">← Back</a>
      </div>
    </div>
    <% if (contract) { %>
      <div style="font-family:'Courier New',monospace;font-size:.88rem;line-height:1.7;white-space:pre-wrap;background:#f8f9fa;border:1px solid var(--border);border-radius:8px;padding:1.25rem;"><%= contract %></div>
      <div style="margin-top:1rem;padding:.75rem;background:#ede9fe;border-radius:8px;font-size:.83rem;color:#5b21b6;">
        ⚠️ This contract was generated by AI for reference purposes. For legally binding agreements, please consult a legal professional.
      </div>
    <% } else { %>
      <div style="text-align:center;padding:2rem;">
        <div style="font-size:2rem;margin-bottom:.5rem;">🤖</div>
        <p style="color:var(--dark4);">AI contract generation requires a GEMINI_API_KEY in your .env file.</p>
        <p style="font-size:.85rem;color:var(--dark4);">Get a free key at <a href="https://aistudio.google.com" target="_blank">aistudio.google.com</a></p>
      </div>
    <% } %>
  </div>
</div>
<style>@media print { .navbar,.page-header,.btn { display:none; } }</style>
<%- include('../layout/footer') %>
